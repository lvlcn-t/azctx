Set Shell "bash"
Set FontSize 16
Set Width 1200
Set Height 600
Set Theme {
  "background":   "#0D1117",
  "foreground":   "#CDD6F4",
  "cursor":       "#50E6FF",
  "selection":    "#003B73",
  "black":        "#1E1E2E",
  "red":          "#F38BA8",
  "green":        "#54B948",
  "yellow":       "#F9E2AF",
  "blue":         "#0078D4",
  "magenta":      "#CBA6F7",
  "cyan":         "#50E6FF",
  "white":        "#A19F9D",
  "brightBlack":  "#585B70",
  "brightRed":    "#F38BA8",
  "brightGreen":  "#A6E3A1",
  "brightYellow": "#F9E2AF",
  "brightBlue":   "#50E6FF",
  "brightMagenta":"#F5C2E7",
  "brightCyan":   "#50E6FF",
  "brightWhite":  "#CDD6F4"
}

Output {{ .Out }}

Hide
Type "export PATH={{ .BinDir }}:$PATH"
Enter
Type "export AZCTX={{ .CfgPath }}"
Enter
Type "clear"
Enter
Show

Require azctx
Require az

Type "azctx"
Enter
Sleep 700ms

# Navigate down through contexts
Down
Sleep 400ms
Down
Sleep 400ms

# Tab → Tenants
Tab
Sleep 600ms

# Tab → Credentials
Tab
Sleep 600ms

# Tab → back to Contexts
Tab
Sleep 400ms
Type "/west"
Sleep 600ms

# Quit without switching
Type "q"
Sleep 300ms
